{
  admin off
  auto_https off
}

(protected) {
  forward_auth authelia:9091 {
    uri /api/verify?rd=https://auth.databunker.uk
    copy_headers Remote-User Remote-Groups Remote-Name Remote-Email
    header_up X-Forwarded-Proto https
  }
}

:80 {
  @auth host auth.databunker.uk
  handle @auth {
    reverse_proxy authelia:9091
  }

  @status host status.databunker.uk
  handle @status {
    reverse_proxy host.docker.internal:3001
  }

  @affine host affine.databunker.uk
  handle @affine {
    reverse_proxy host.docker.internal:3010
  }

  @pdf host pdf.databunker.uk
  handle @pdf {
    import protected
    reverse_proxy host.docker.internal:8080
  }

  @joules host joules.me
  handle @joules {
    reverse_proxy host.docker.internal:8687
  }

  @stillhere host stillherehq.com www.stillherehq.com
  handle @stillhere {
    reverse_proxy stillhere-api:8000
  }

  @sync host sync.databunker.uk
  handle @sync {
    import protected
    reverse_proxy syncthing:8384 {
      header_up Host localhost
    }
  }

  @shadow host shadow.databunker.uk
  handle @shadow {
    reverse_proxy host.docker.internal:3004
  }

  @attentive host attentive.databunker.uk attentive.fyi
  handle @attentive {
    reverse_proxy attentive:3003
  }

  # Catch-all: return 404 for unmatched hosts instead of silent 200
  handle {
    respond 404
  }
}
