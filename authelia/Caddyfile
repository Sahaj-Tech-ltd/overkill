{
  admin off
  auto_https off
  servers {
    trusted_proxies static private_ranges
    max_header_size 16384
    timeouts {
      read_body 30s
      read_header 10s
      write 60s
      idle 5m
    }
  }
}

(protected) {
  forward_auth authelia:9091 {
    uri /api/verify?rd=https://auth.harshvardhanrathi.com
    copy_headers Remote-User Remote-Groups Remote-Name Remote-Email
    header_up X-Forwarded-Proto https
  }
}

:80 {
  # JSON access log for fail2ban
  log {
    output file /var/log/caddy/access.log {
      roll_size 50mb
      roll_keep 5
    }
    format json
  }

  # Global: hang up on bot/scanner probes without wasting backend compute
  @botBlock {
    path *.php *.php?* *.asp *.aspx *.jsp *.cgi
    path /wp-* /wp-admin* /wp-content* /wp-includes* /xmlrpc*
    path /.env* /.git* /.aws* /config* /.DS_Store
    path /admin* /administrator* /backup* /cgi-bin/*
  }
  handle @botBlock {
    respond 444
  }

  # Global: per-IP+host rate limit (500 req/min per IP per host, real client IP via CF-Connecting-IP header)
  # Bumped from 300 to 500 and key changed to include host (2026-06-27): internal monitoring
  # bursts (push monitors, content checks, stack health checks) were exhausting the per-IP
  # bucket, causing 429s for unrelated services. Keying by IP+host isolates traffic so
  # push monitor bursts to status.harshvardhanrathi.com don't block overkill.my checks.
  rate_limit {
    zone dynamic {
      key {http.request.header.CF-Connecting-IP}_{http.request.host}
      events 500
      window 1m
    }
  }

  @auth host auth.harshvardhanrathi.com
  handle @auth {
    reverse_proxy authelia:9091
  }

  @status host status.harshvardhanrathi.com
  handle @status {
    reverse_proxy host.docker.internal:3001
  }

  @affine host affine.harshvardhanrathi.com
  handle @affine {
    reverse_proxy host.docker.internal:3010
  }

  @pdf host pdf.harshvardhanrathi.com
  handle @pdf {
    import protected
    reverse_proxy host.docker.internal:8095
  }

  @joules host joules.me
  handle @joules {
    reverse_proxy host.docker.internal:8687
  }

  @stillhere host stillherehq.com www.stillherehq.com
  handle @stillhere {
    reverse_proxy stillhere-api:8000
  }

  @sync host sync.harshvardhanrathi.com
  handle @sync {
    import protected
    reverse_proxy syncthing:8384 {
      header_up Host localhost
    }
  }

  @harsha host harshvardhanrathi.com www.harshvardhanrathi.com
  handle @harsha {
    handle_path /agentphone-webhook* {
      reverse_proxy agentphone-webhook:8098
    }
    reverse_proxy shadow:3000
  }

  @attentive host attentive.fyi
  handle @attentive {
    reverse_proxy attentive:3003
  }

  @builders host builders.harshvardhanrathi.com
  handle @builders {
    reverse_proxy host.docker.internal:8182
  }

  @sign host sign.harshvardhanrathi.com
  handle @sign {
    reverse_proxy host.docker.internal:3002
  }

  @ntfy host ntfy.harshvardhanrathi.com
  handle @ntfy {
    reverse_proxy host.docker.internal:2586
  }

  @ladder host ladder.harshvardhanrathi.com
  handle @ladder {
    import protected
    reverse_proxy host.docker.internal:8587
  }

  @overkill host overkill.my
  handle @overkill {
    @install path /install
    handle @install {
      rewrite * /install.sh
    }
    @exclusives path /exclusives
    handle @exclusives {
      rewrite * /exclusives.html
    }
    @memo path /memo
    handle @memo {
      rewrite * /memo.html
    }
    file_server {
      root /srv/overkill.my
    }
  }

  @nextcloud host cloud.harshvardhanrathi.com
  handle @nextcloud {
    reverse_proxy host.docker.internal:8093
  }

  @addy host addy.databunker.uk
  handle @addy {
    reverse_proxy addy:8000 {
      header_up X-Forwarded-Proto https
    }
  }

  @sahajtech host sahajtech.dev www.sahajtech.dev

  @fixate host fixate.sahajtech.dev
  handle @fixate {
    reverse_proxy 172.17.0.1:8096
  }
  handle @sahajtech {
    handle /fixate* {
      reverse_proxy 172.17.0.1:8096
    }
    reverse_proxy sahajtech:80
  }

  @agentphone host agentphone.databunker.uk
  handle @agentphone {
    reverse_proxy agentphone-webhook:8098
  }

  @trek host trek.harshvardhanrathi.com
  handle @trek {
    import protected
    reverse_proxy trek:3000
  }

  @chatto host chat.harshvardhanrathi.com
  handle @chatto {
    reverse_proxy chatto:4000 {
      header_up X-Real-IP {http.request.remote.host}
    }
    encode gzip zstd
  }

  @livekit host livekit.chat.harshvardhanrathi.com
  handle @livekit {
    reverse_proxy livekit:7880
  }

  @microbin host share.harshvardhanrathi.com
  handle @microbin {
    @upload method POST
    basicauth @upload {
      butter $2a$14$9TK2H7diF/SkMqocjTVOteQkN/cs/3lozb9rzoiL2GEFHdU5kw8wS
    }
    reverse_proxy host.docker.internal:8099
  }

  # Catch-all: return 404 for unmatched hosts instead of silent 200
  handle {
    respond 404
  }
}
